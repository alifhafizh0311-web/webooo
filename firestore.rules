rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email.lower() == "alifhafizh0311@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    function isOwner(email) {
      return isAuthenticated() && 
             request.auth.token.email != null && 
             request.auth.token.email.lower() == email.lower();
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['user', 'admin'];
    }

    function isValidChat(data) {
      return data.keys().hasAll(['userEmail', 'packageId', 'messages', 'status']) &&
             data.userEmail is string && data.userEmail.size() > 0 &&
             data.packageId is string && data.packageId.size() > 0 &&
             data.messages is list &&
             data.status in ['open', 'closed'];
    }

    function isValidTestimonial(data) {
      return data.keys().hasAll(['name', 'role', 'text']) &&
             data.name is string && data.name.size() > 0 &&
             data.role is string &&
             data.text is string && data.text.size() > 0;
    }

    function isValidPackage(data) {
      return data.keys().hasAll(['name', 'price', 'features']) &&
             data.name is string && data.name.size() > 0 &&
             data.price is number &&
             data.features is list;
    }

    function isValidPromo(data) {
      return data.keys().hasAll(['code', 'discountPercent']) &&
             data.code is string && data.code.size() > 0 &&
             data.discountPercent is number;
    }

    function isValidPublicChat(data) {
      return data.keys().hasAll(['sender', 'senderEmail', 'text', 'timestamp']) &&
             data.sender is string &&
             data.senderEmail is string &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             data.timestamp is number;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data);
      allow update: if isAdmin() && isValidUser(request.resource.data);
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.userEmail) || isAdmin());
      allow create: if isAuthenticated() && isOwner(request.resource.data.userEmail) && isValidChat(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(resource.data.userEmail) || isAdmin()) && isValidChat(request.resource.data);
      allow delete: if isAdmin();
    }

    match /testimonials/{id} {
      allow read: if true;
      allow write: if isAdmin() && isValidTestimonial(request.resource.data);
    }

    match /packages/{id} {
      allow read: if true;
      allow write: if isAdmin() && isValidPackage(request.resource.data);
    }

    match /promos/{code} {
      allow read: if true;
      allow write: if isAdmin() && isValidPromo(request.resource.data);
    }

    match /public_chats/{id} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                    (request.resource.data.senderEmail == request.auth.token.email || isAdmin()) && 
                    isValidPublicChat(request.resource.data);
      allow delete: if isAdmin();
    }

    match /test/{id} {
      allow read: if true;
    }
  }
}
