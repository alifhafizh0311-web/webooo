rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "alifhafizh0311@gmail.com";
    }

    function isOwner(email) {
      return isAuthenticated() && request.auth.token.email == email;
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['email', 'role']) &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['user', 'admin'];
    }

    function isValidChat(data) {
      return data.keys().hasOnly(['userEmail', 'packageId', 'messages', 'status']) &&
             data.userEmail is string && data.userEmail.size() > 0 &&
             data.packageId is string && data.packageId.size() > 0 &&
             data.messages is list &&
             data.status in ['open', 'closed'];
    }

    function isValidTestimonial(data) {
      return data.keys().hasOnly(['name', 'role', 'text']) &&
             data.name is string && data.name.size() > 0 &&
             data.role is string && data.role.size() > 0 &&
             data.text is string && data.text.size() > 0;
    }

    function isValidPackage(data) {
      return data.keys().hasOnly(['name', 'price', 'features']) &&
             data.name is string && data.name.size() > 0 &&
             data.price is number && data.price >= 0 &&
             data.features is list;
    }

    function isValidPromo(data) {
      return data.keys().hasOnly(['code', 'discountPercent']) &&
             data.code is string && data.code.size() > 0 &&
             data.discountPercent is number && data.discountPercent >= 0 && data.discountPercent <= 100;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data);
      allow update: if isAdmin() && isValidUser(request.resource.data);
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.userEmail) || isAdmin());
      allow create: if isAuthenticated() && isOwner(request.resource.data.userEmail) && isValidChat(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(resource.data.userEmail) || isAdmin()) && isValidChat(request.resource.data);
      allow delete: if isAdmin();
    }

    match /testimonials/{id} {
      allow read: if true;
      allow write: if isAdmin() && isValidTestimonial(request.resource.data);
    }

    match /packages/{id} {
      allow read: if true;
      allow write: if isAdmin() && isValidPackage(request.resource.data);
    }

    match /promos/{code} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidPromo(request.resource.data);
    }
  }
}
